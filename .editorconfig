# EditorConfig helps maintain consistent coding style across different editors
# https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript, JSON, Markdown
[*.{js,json,md}]
indent_style = space
indent_size = 2

# YAML
[*.yml]
indent_style = space
indent_size = 2

# Makefile
[Makefile]
indent_style = tab
