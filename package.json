{
  "name": "@studioframes/condense",
  "version": "0.3.5",
  "description": "Condense is a high-performance, stateless file optimization and minification engine for Node.js.",
  "main": "src/index.js",
  "bin": {
    "@studioframes/condense": "./bin/cli.js"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "build": "echo 'This project doesn't require building anything.'",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint src/ bin/ tests/",
    "format": "prettier --write ."
  },
  "keywords": [
    "minify",
    "compress",
    "optimize",
    "image",
    "video",
    "middleware",
    "stateless"
  ],
  "author": "Studio Frames",
  "license": "Apache-2.0",
  "dependencies": {
    "clean-css": "^5.3.3",
    "esbuild": "^0.28.1",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "html-minifier-terser": "^7.2.0",
    "htmlparser2": "^12.0.0",
    "js-yaml": "^5.2.1",
    "lru-cache": "^11.5.2",
    "multer": "^2.2.0",
    "sharp": "^0.35.3",
    "svgo": "^4.0.1",
    "terser": "^5.49.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/studioframes/Condense.git"
  },
  "bugs": {
    "url": "https://github.com/studioframes/Condense/issues"
  },
  "homepage": "https://condense.js.org",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.5"
  }
}
